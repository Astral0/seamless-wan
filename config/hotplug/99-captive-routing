#!/bin/sh
# seamless-wan: UID-based policy routing for captive portal user
# When wan2 comes up, add ip rule so user "captive" (UID 15) traffic
# goes directly through WiFi (bypassing the VPN tunnel).
[ "$INTERFACE" = "wan2" ] && [ "$ACTION" = "ifup" ] && {
    TABLE=$(uci get network.wan2.ip4table 2>/dev/null)
    [ -z "$TABLE" ] && exit 0
    DEVICE=$(uci get network.wan2.device 2>/dev/null)
    [ -z "$DEVICE" ] && exit 0

    # Add ip rule for captive user
    ip rule show | grep -q 'uidrange 15-15' || {
        ip rule add uidrange 15-15 table $TABLE prio 5000
        logger -t captive-routing "Added ip rule for uid 15 -> table $TABLE"
    }

    # Wait for gateway to be available, then add default route
    tries=0
    while [ $tries -lt 10 ]; do
        GW=$(ip route show dev $DEVICE | grep default | awk '{print $3}' | head -1)
        if [ -n "$GW" ]; then
            ip route show table $TABLE | grep -q default || {
                ip route add default via $GW dev $DEVICE table $TABLE
                logger -t captive-routing "Added default route via $GW dev $DEVICE table $TABLE"
            }
            break
        fi
        tries=$((tries + 1))
        sleep 2
    done
}
